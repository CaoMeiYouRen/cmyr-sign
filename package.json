{
  "name": "cmyr-sign",
  "version": "1.1.3",
  "description": "草梅友仁设计的计算签名和校验签名的包",
  "author": "CaoMeiYouRen",
  "private": false,
  "type": "module",
  "license": "MIT",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "eslint src --fix",
    "release": "semantic-release",
    "prebuild": "rimraf dist",
    "build": "cross-env NODE_ENV=production tsdown",
    "dev": "tsx watch src/index.ts",
    "dev:tsdown": "tsdown --watch",
    "rm": "rimraf node_modules",
    "start": "node ./dist/index.cjs",
    "commit": "cz",
    "prepare": "husky install",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@types/debug": "^4.1.7",
    "@types/md5": "^2.3.2",
    "@types/node": "^25.0.3",
    "@types/qs": "^6.9.7",
    "@vitest/coverage-v8": "^4.0.18",
    "commitizen": "^4.3.0",
    "commitlint-config-cmyr": "^1.0.0",
    "cross-env": "^10.0.0",
    "cz-conventional-changelog-cmyr": "^2.0.0",
    "debug": "^4.3.4",
    "eslint": "^10.0.2",
    "eslint-config-cmyr": "^2.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "rimraf": "^6.0.0",
    "semantic-release": "^25.0.3",
    "semantic-release-cmyr-config": "^1.0.1",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog-cmyr"
    }
  },
  "changelog": {
    "language": "zh"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "npm run lint",
      "git add"
    ]
  },
  "keywords": [],
  "homepage": "https://github.com/CaoMeiYouRen/cmyr-sign#readme",
  "bugs": {
    "url": "https://github.com/CaoMeiYouRen/cmyr-sign/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "md5": "2.3.0",
    "qs": "6.15.0",
    "tslib": "^2.5.0"
  },
  "pnpm": {
    "overrides": {
      "@semantic-release/github": "^12.0.0",
      "@semantic-release/npm": "^13.1.0"
    }
  }
}
