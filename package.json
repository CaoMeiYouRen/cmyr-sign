{
  "name": "cmyr-sign",
  "version": "1.1.2",
  "description": "草梅友仁设计的计算签名和校验签名的包",
  "author": "CaoMeiYouRen",
  "private": false,
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    },
    "./browser": {
      "require": "./dist/browser.js",
      "import": "./dist/browser.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "cross-env NODE_ENV=production eslint src --fix",
    "release": "semantic-release",
    "prebuild": "rimraf dist",
    "build": "cross-env NODE_ENV=production rollup -c",
    "analyzer": "cross-env NODE_ENV=production ANALYZER=true rollup -c",
    "dev": "cross-env NODE_ENV=development ts-node-dev src/index.ts",
    "dev:rollup": "cross-env NODE_ENV=development rollup -c -w",
    "rm": "rimraf node_modules",
    "start": "node ./dist/index",
    "commit": "cz",
    "prepare": "husky install",
    "test": "jest",
    "test:cov": "jest --coverage"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "latest",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.1",
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/debug": "^4.1.7",
    "@types/jest": "^29.5.0",
    "@types/md5": "^2.3.2",
    "@types/node": "^25.0.3",
    "@types/qs": "^6.9.7",
    "commitizen": "^4.3.0",
    "commitlint-config-cmyr": "^1.0.0",
    "cross-env": "^10.0.0",
    "cz-conventional-changelog-cmyr": "^2.0.0",
    "debug": "^4.3.4",
    "eslint": "^10.0.2",
    "eslint-config-cmyr": "^2.1.4",
    "husky": "^9.1.7",
    "jest": "^29.5.0",
    "lint-staged": "^16.3.1",
    "rimraf": "^6.0.0",
    "rollup": "^4.18.0",
    "rollup-plugin-analyzer": "^4.0.0",
    "rollup-plugin-dts": "^6.1.1",
    "semantic-release": "^25.0.3",
    "semantic-release-cmyr-config": "^1.0.1",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.9.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog-cmyr"
    }
  },
  "changelog": {
    "language": "zh"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "npm run lint",
      "git add"
    ]
  },
  "keywords": [],
  "homepage": "https://github.com/CaoMeiYouRen/cmyr-sign#readme",
  "bugs": {
    "url": "https://github.com/CaoMeiYouRen/cmyr-sign/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "md5": "2.3.0",
    "qs": "6.15.0",
    "tslib": "^2.5.0"
  }
}